// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id            String          @id @default(cuid())
  name          String          @unique
  slug          String          @unique
  description   String?
  cloudProvider String          // "Azure" o "AWS"
  members       TeamMember[]
  advances      AdvanceReport[]
  diagrams      DiagramState[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model TeamMember {
  id             String   @id @default(cuid())
  fullName       String
  email          String?
  role           String
  isGlobalLeader Boolean  @default(false)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
}

model AdvanceReport {
  id            String   @id @default(cuid())
  sprintNumber  Int
  title         String
  description   String   @db.Text
  status        String   @default("Pendiente")
  
  dateRange     String?  
  progress      Int      @default(0) 
  objectives    String[] @default([]) 
  achievements  String[] @default([]) 
  blockers      String[] @default([]) // NUEVO CAMPO: Para impedimentos (Amarillo)
  nextSteps     String[] @default([]) 
  areasProgress Json?    

  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, sprintNumber])
}

model DiagramState {
  id        String   @id @default(cuid())
  viewName  String
  nodes     Json
  edges     Json
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([projectId, viewName])
}